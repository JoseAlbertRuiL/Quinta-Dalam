---
// ↓ Importamos nuestra Plantilla Base
import Layout from "../layouts/Layout.astro";
// ↓ Importamos el componente Image para optimizar imágenes pesadas
import { Image } from "astro:assets";
import habitacionImg from "../assets/images/habitacion.png";
// ↓ Importamos nuestra hoja de estilos dedicada a nuestras habitaciones
import "../styles/habitaciones.css";
---

<Layout title="Habitaciones | Hotel Quinta Dalam">
  <main>
    <!-- * <main>: Define el contenido principal y único de la página web dentro del <body> -->
    <!-- TODO (Alberto): Darle estilado a la página dentro de la hoja de estilos CSS -->
    <!-- TODO (José): Terminar de crear un buen formato para la página, explicando la temática de cada habitación culturalmente -->
    <section>
      <header>
        <h2>Habitaciones</h2>
      </header>
      <div>
        <p>
          ¿Estás listo para probar nuestras 15 experiencias únicas sobre
          Michoacán?
          <br />
          En Hotel Quinta Dalam, cada habitación es un refugio de relajación y comodidad,
          pero sobre todo, de tradiciones, cultura y arte.
        </p>
      </div>
    </section>

    <section id="lista-habitaciones">
      <!-- Planta Baja -->
      <div id="planta-baja">
        <h3>Planta Baja (Serie 100)</h3>
        <div class="habitaciones-grid">
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 101 - Tzintzunzan"
              width={400}
              height={150}
            />
            <h4>101 - Tzintzunzan</h4>
            <p class="precio">$1,200 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 102 - Paracho"
              width={400}
              height={150}
            />
            <h4>102 - Paracho</h4>
            <p class="precio">$1,100 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 103 - Yunuen"
              width={400}
              height={150}
            />
            <h4>103 - Yunuen</h4>
            <p class="precio">$1,150 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 104 - Patzcuaro"
              width={400}
              height={150}
            />
            <h4>104 - Patzcuaro</h4>
            <p class="precio">$1,300 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 105 - Coeneo"
              width={400}
              height={150}
            />
            <h4>105 - Coeneo</h4>
            <p class="precio">$1,050 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 106 - Janitzio"
              width={400}
              height={150}
            />
            <h4>106 - Janitzio</h4>
            <p class="precio">$1,250 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
        </div>
      </div>

      <!-- Planta Alta -->
      <div id="planta-alta">
        <h3>Planta Alta (Serie 200)</h3>
        <div class="habitaciones-grid">
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 201 - Suite Quencio"
              width={400}
              height={150}
            />
            <h4>201 - Suite Quencio</h4>
            <p class="precio">$1,500 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 202 - Morelia"
              width={400}
              height={150}
            />
            <h4>202 - Morelia</h4>
            <p class="precio">$1,400 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 203 - Tacambaro"
              width={400}
              height={150}
            />
            <h4>203 - Tacambaro</h4>
            <p class="precio">$1,350 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 204 - Uruapan"
              width={400}
              height={150}
            />
            <h4>204 - Uruapan</h4>
            <p class="precio">$1,450 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 205 - Tlalpujahua"
              width={400}
              height={150}
            />
            <h4>205 - Tlalpujahua</h4>
            <p class="precio">$1,200 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 206 - Cuitzeo"
              width={400}
              height={150}
            />
            <h4>206 - Cuitzeo</h4>
            <p class="precio">$1,300 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
          <div class="habitacion-card">
            <Image
              src={habitacionImg}
              alt="Habitación 207 - Cuanajo"
              width={400}
              height={150}
            />
            <h4>207 - Cuanajo</h4>
            <p class="precio">$1,350 MXN/noche</p>
            <button class="btn-reservar">Reservar</button>
          </div>
        </div>
      </div>
    </section>

    <section id="explicaciones">
      <div>
        <header>
          <h2>¿Quieres saber un poco más sobre cada una?</h2>
        </header>
        <p></p>
        <!-- * habitacion2.png pesa solo 167KB, se queda en public/images sin necesitar optimización -->
        <img src="/images/habitacion2.png" alt="Habitación 2" loading="lazy" />
      </div>
    </section>
  </main>
</Layout>
