---
// ↓ Importamos nuestra Plantilla Base para admin/
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
// ↓ Importamos el componente de navegación reutilizable del panel
import NavAdmin from "../../components/NavAdmin.astro";
import { supabase } from "../../lib/supabase";

// LA AUTENTICACIÓN AHORA LA MANEJA src/middleware.ts
---

<LayoutAdmin title="Admin | Inbox" favicon="/images/inbox-icono.png">
  <header class="py-10 px-4 text-center">
    <h1 class="text-3xl font-bold text-white flex items-center justify-center gap-3">
      <i class="fa-solid fa-gears text-blue-500" aria-hidden="true"></i>
      Panel de Administración
    </h1>
  </header>

  <div class="w-full px-4 md:px-8 pb-10">
    <div class="flex flex-col md:flex-row gap-6">
      <!-- ! Columna 1: de Navegación -->
      <NavAdmin paginaActual="inbox" />

      <!-- ! Columna 2: Contenido Principal -->
      <div class="flex-1">
        <main class="bg-[#141414] p-6 lg:p-8 rounded-xl border border-neutral-800/50 shadow-lg">
          <section id="inbox">
            <!-- ? Box de Mensajes -->
            <details open class="bg-[#0a0a0a] rounded-xl border border-neutral-800 p-6">
              <summary class="cursor-pointer list-none m-0 p-0 focus:outline-none">
                <h3 class="text-xl font-bold text-white inline-flex items-center gap-3 m-0">
                  <i class="fa-solid fa-inbox text-blue-500"></i>
                  Mensajes
                </h3>
              </summary>
              <div class="mt-6 pl-5 border-l-4 border-l-blue-600">
                <p class="text-neutral-300 font-medium mb-4">¡Tienes 2 mensajes nuevos!</p>
                <div class="bg-[#141414] rounded-lg border border-neutral-800 p-5 space-y-4">
                  <blockquote class="text-neutral-400 pl-4 border-l-2 border-neutral-700 italic">
                    "¡Buenas tarde! Espero esté disfrutando de la página web,
                    cualquier cosa que necesite avísenos a la brevedad y le
                    daremos solución lo más rápido posible"
                    <footer class="text-neutral-500 mt-2 not-italic font-semibold">- <cite>José Luis</cite></footer>
                  </blockquote>
                  <blockquote class="text-neutral-400 pl-4 border-l-2 border-neutral-700 italic">
                    "La página ya quedó lista y funcional, pero aún podemos
                    seguir mejorándola."
                    <footer class="text-neutral-500 mt-2 not-italic font-semibold">- <cite>José Alberto</cite></footer>
                  </blockquote>
                </div>
              </div>
            </details>
          </section>
        </main>
      </div>
    </div>
  </div>
</LayoutAdmin>
