---
// ↓ Importamos nuestra Plantilla Base para admin/
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
// ↓ Importamos el componente de navegación reutilizable del panel
import NavAdmin from "../../components/NavAdmin.astro";
import { supabase } from "../../lib/supabase";

// LA AUTENTICACIÓN AHORA LA MANEJA src/middleware.ts

// CÁLCULOS FINANCIEROS (Simulación + Datos BD)
// En un caso real agruparías por fecha con sentencias SQL, aquí lo procesamos en JS para el demo
const { data: reservas } = await supabase.from("reservas").select("*");

// Calculamos un estimado de ingresos Brutos del mes en base a reservas (Mock up adaptativo)
const ingresoBruto = 145800.0; // Valor de ejemplo para la demo financiera
const iva = ingresoBruto * 0.16; // 16% IVA Mexicano
const ingresoNeto = ingresoBruto - iva;

const gastosOperativos = 25000.0;
const gananciaReal = ingresoNeto - gastosOperativos;
---

<LayoutAdmin title="Admin | Estadísticas" favicon="/images/stats-icono.png">
  <header class="py-10 px-4 text-center">
    <h1 class="text-3xl font-bold text-white flex items-center justify-center gap-3">
      <i class="fa-solid fa-gears text-blue-500" aria-hidden="true"></i>
      Panel de Administración
    </h1>
  </header>

  <div class="w-full px-4 md:px-8 pb-10">
    <div class="flex flex-col md:flex-row gap-6">
      <!-- ! Columna 1: de Navegación -->
      <NavAdmin paginaActual="stats" />

      <!-- ! Columna 2: Contenido Principal -->
      <div class="flex-1">
        <main class="bg-[#141414] p-6 lg:p-8 rounded-xl border border-neutral-800/50 shadow-lg">
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="fa-solid fa-chart-column text-blue-500"></i> Reporte Financiero
            y Estadísticas
          </h2>

          <!-- KPIs Financieros -->
          <div class="flex flex-wrap justify-between gap-4 p-6 bg-[#0a0a0a] rounded-xl border border-neutral-800 mb-8">
            <div class="flex-1 text-center min-w-[150px]">
              <p class="text-xs uppercase tracking-widest text-neutral-400 mb-1 font-semibold">
                Ingreso Bruto (Mensual)
              </p>
              <p class="text-3xl font-bold text-white">
                ${ingresoBruto.toLocaleString("es-MX")} MXN
              </p>
            </div>
            <div class="flex-1 text-center min-w-[150px]">
              <p class="text-xs uppercase tracking-widest text-red-500 mb-1 font-semibold">Impuestos (IVA 16%)</p>
              <p class="text-3xl font-bold text-red-500">
                -${iva.toLocaleString("es-MX")} MXN
              </p>
            </div>
            <div class="flex-1 text-center min-w-[150px]">
              <p class="text-xs uppercase tracking-widest text-green-500 mb-1 font-semibold">Ingreso Neto</p>
              <p class="text-3xl font-bold text-green-500">
                ${ingresoNeto.toLocaleString("es-MX")} MXN
              </p>
            </div>
            <div class="flex-1 text-center min-w-[150px]">
              <p class="text-xs uppercase tracking-widest text-blue-400 mb-1 font-semibold">Ganancia Real Estimada</p>
              <p class="text-3xl font-bold text-blue-400">
                ${gananciaReal.toLocaleString("es-MX")} MXN
              </p>
            </div>
          </div>

          <!-- Gráficas -->
          <div class="flex flex-col xl:flex-row gap-6 mb-8">
            <div class="flex-1 xl:w-7/12">
              <div class="bg-[#0a0a0a] p-6 rounded-xl border border-neutral-800 h-full">
                <h3 class="text-lg font-semibold text-white text-center mb-6">
                  Ingresos Históricos (Últimos 6 Meses)
                </h3>
                <canvas id="barChart"></canvas>
              </div>
            </div>
            <div class="flex-1 xl:w-5/12">
              <div class="bg-[#0a0a0a] p-6 rounded-xl border border-neutral-800 h-full">
                <h3 class="text-lg font-semibold text-white text-center mb-6">
                  Distribución de Ingresos
                </h3>
                <div class="relative h-[280px] w-full flex justify-center items-center">
                  <canvas id="pieChart"></canvas>
                </div>
              </div>
            </div>
          </div>

          <!-- Manejo de Sueldos (Mock) -->
          <div class="bg-[#0a0a0a] p-6 rounded-xl border border-neutral-800 border-l-4 border-l-yellow-500">
            <div class="flex justify-between items-center mb-6 flex-wrap gap-4">
              <h3 class="text-lg font-semibold text-white flex items-center gap-2 m-0">
                <i class="fa-solid fa-file-invoice-dollar text-yellow-500"
                ></i> Nómina y Sueldos del Personal
              </h3>
              <button class="border border-yellow-500 text-yellow-500 hover:bg-yellow-500 hover:text-black px-4 py-1.5 text-sm rounded-lg transition-colors font-medium cursor-pointer"
                >Generar Recibos</button
              >
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse text-sm whitespace-nowrap">
                <thead>
                  <tr>
                    <th class="border-b border-neutral-800 py-3 px-3 text-neutral-400 font-medium">Empleado</th>
                    <th class="border-b border-neutral-800 py-3 px-3 text-neutral-400 font-medium">Puesto</th>
                    <th class="border-b border-neutral-800 py-3 px-3 text-neutral-400 font-medium">Sueldo Base</th>
                    <th class="border-b border-neutral-800 py-3 px-3 text-neutral-400 font-medium">Bonos/Deducciones</th>
                    <th class="border-b border-neutral-800 py-3 px-3 text-neutral-400 font-medium">Total a Pagar</th>
                    <th class="border-b border-neutral-800 py-3 px-3 text-neutral-400 font-medium">Estado</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="hover:bg-neutral-900/40 transition-colors">
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-white font-medium">Carlos Martínez</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-neutral-300">Gerente Turno Día</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-neutral-300">$12,000 MXN</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-green-500">+$1,500 MXN (Bono)</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-white font-bold">$13,500 MXN</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">Pagado</span>
                    </td>
                  </tr>
                  <tr class="hover:bg-neutral-900/40 transition-colors">
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-white font-medium">Ana Sofía López</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-neutral-300">Recepción Turno Noche</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-neutral-300">$8,500 MXN</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-neutral-500">-</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-white font-bold">$8,500 MXN</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">Pendiente</span>
                    </td>
                  </tr>
                  <tr class="hover:bg-neutral-900/40 transition-colors">
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-white font-medium">Raúl Gómez</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-neutral-300">Mantenimiento</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-neutral-300">$7,200 MXN</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-red-500">-$200 MXN (Retardo)</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50 text-white font-bold">$7,000 MXN</td>
                    <td class="py-3 px-3 border-b border-neutral-800/50">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">Pendiente</span>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>

  <!-- Scripts para Chart.js cargados de NPM (Vite bundle) -->
  <script>
    import Chart from "chart.js/auto";

    document.addEventListener("DOMContentLoaded", () => {
      // Gráfica de Barras
      const barEl = document.getElementById("barChart") as HTMLCanvasElement | null;
      if (!barEl) return;
      
      new Chart(barEl, {
        type: "bar",
        data: {
          labels: ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio"],
          datasets: [
            {
              label: "Ingresos Brutos (MXN)",
              data: [95000, 110000, 105000, 130000, 125000, 145800],
              backgroundColor: "rgba(50, 152, 220, 0.6)", // Bulma info color
              borderColor: "rgba(50, 152, 220, 1)",
              borderWidth: 1,
            },
          ],
        },
        options: {
          responsive: true,
          plugins: { legend: { labels: { color: "#fff" } } },
          scales: {
            y: { ticks: { color: "#b5b5b5" }, grid: { color: "#363636" } },
            x: { ticks: { color: "#b5b5b5" }, grid: { color: "#363636" } },
          },
        },
      });

      // Gráfica de Pastel
      const pieEl = document.getElementById("pieChart") as HTMLCanvasElement | null;
      if (!pieEl) return;
      
      new Chart(pieEl, {
        type: "doughnut",
        data: {
          labels: ["Suites", "Doble", "Estándar", "Servicios Extra"],
          datasets: [
            {
              data: [45, 25, 20, 10],
              backgroundColor: [
                "rgba(72, 199, 116, 0.8)", // success
                "rgba(50, 152, 220, 0.8)", // info
                "rgba(255, 221, 87, 0.8)", // warning
                "rgba(241, 70, 104, 0.8)", // danger
              ],
              borderWidth: 0,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: "bottom", labels: { color: "#fff" } },
          },
        },
      });
    });
  </script>
</LayoutAdmin>
