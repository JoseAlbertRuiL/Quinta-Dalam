---
// ↓ Importamos nuestra Plantilla Base para admin/
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
// ↓ Importamos el componente de navegación reutilizable del panel
import NavAdmin from "../../components/NavAdmin.astro";
import { createClient } from "@supabase/supabase-js";
import type { Database } from "../../lib/database.types";

// LA AUTENTICACIÓN AHORA LA MANEJA src/middleware.ts
// El usuario que llega aquí ya tiene una sesión validada y rol comprobado.

// ─── Cliente Admin para queries SSR del panel ──────────────────────────
// Usamos service_role para garantizar que RLS no bloquee las consultas.
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;

if (!supabaseUrl || !supabaseKey) {
  throw new Error("[panel-admin] Faltan credenciales de servicio en .env");
}

const supabaseAdmin = createClient<Database>(supabaseUrl, supabaseKey);

// OBTENCIÓN DE DATOS PARA EL DASHBOARD
const { data: habitaciones } = await supabaseAdmin
  .from("habitaciones")
  .select("*");
const { data: reservas } = await supabaseAdmin.from("reservas").select("*");

// ─── Lógica de Habitaciones y Fechas ─────────────────────────────────
const hoy = new Date();
hoy.setHours(0, 0, 0, 0); // Normalizar a inicio del día para comparaciones precisas

// Reservas activas HOY (para determinar estado de habitaciones)
// BUG FIX: salida > hoy (exclusivo) — si hoy == fecha_salida, el cliente ya hizo checkout
const reservasActivas =
  reservas?.filter((r) => {
    const entrada = new Date(r.fecha_entrada + "T00:00:00");
    const salida = new Date(r.fecha_salida + "T00:00:00");
    return entrada <= hoy && salida > hoy;
  }) || [];

// ─── Matching atómico: reservas.habitacion === habitaciones.nombre ────
// reservas.habitacion almacena el nombre exacto (ej: "101: Tzintzunzan")
// que coincide 1:1 con habitaciones.nombre. Sin fuzzy matching.

const habitacionesStats =
  habitaciones
    ?.map((hab) => {
      const reserva = reservasActivas.find((r) => r.habitacion === hab.nombre);
      return {
        ...hab,
        ocupada: !!reserva,
        fecha_salida: reserva ? reserva.fecha_salida : null,
        cliente: reserva ? reserva.nombre_cliente : null,
      };
    })
    .sort((a, b) => (a.ocupada === b.ocupada ? 0 : a.ocupada ? -1 : 1)) || [];

// ─── Ingresos del MES completo (no solo hoy) ────────────────────────
// Calculamos considerando TODAS las reservas cuya estancia intersecta con el mes actual
const primerDiaMes = new Date(hoy.getFullYear(), hoy.getMonth(), 1);
const ultimoDiaMes = new Date(hoy.getFullYear(), hoy.getMonth() + 1, 0);

const reservasDelMes =
  reservas?.filter((r) => {
    const entrada = new Date(r.fecha_entrada + "T00:00:00");
    const salida = new Date(r.fecha_salida + "T00:00:00");
    return entrada <= ultimoDiaMes && salida >= primerDiaMes;
  }) || [];

const ingresosMes =
  reservasDelMes.length > 0
    ? reservasDelMes.reduce((acc, curr) => {
        const hab = habitaciones?.find((h) => h.nombre === curr.habitacion);
        if (!hab) return acc;
        const inicioEfectivo = new Date(
          Math.max(
            new Date(curr.fecha_entrada + "T00:00:00").getTime(),
            primerDiaMes.getTime(),
          ),
        );
        const finEfectivo = new Date(
          Math.min(
            new Date(curr.fecha_salida + "T00:00:00").getTime(),
            ultimoDiaMes.getTime(),
          ),
        );
        const nochesEnMes = Math.max(
          0,
          Math.ceil(
            (finEfectivo.getTime() - inicioEfectivo.getTime()) / 86400000,
          ),
        );
        return acc + Number(hab.precio) * nochesEnMes;
      }, 0)
    : 0;

const totalReservasMes = reservasDelMes.length;
const habitacionesOcupadas = habitacionesStats.filter((h) => h.ocupada).length;
const habitacionesLibres = habitacionesStats.filter((h) => !h.ocupada).length;

// Nombre del mes actual para la UI
const nombreMes = hoy.toLocaleDateString("es-MX", {
  month: "long",
  year: "numeric",
});
---

<LayoutAdmin title="Admin | Panel General" favicon="/images/admin-icon.png">
  <header class="py-10 px-4 text-center">
    <h1
      class="text-3xl font-bold text-white flex items-center justify-center gap-3"
    >
      <i class="fa-solid fa-gears text-blue-500" aria-hidden="true"></i>
      Panel de Administración
    </h1>
  </header>

  <div class="w-full px-4 md:px-8 pb-10">
    <div class="flex flex-col md:flex-row gap-6">
      <!-- ! Columna 1: de Navegación -->
      <NavAdmin paginaActual="panel-admin" />

      <!-- ! Columna 2: Contenido Principal -->
      <div class="flex-1">
        <main
          class="bg-[#141414] p-6 lg:p-8 rounded-xl border border-neutral-800/50 shadow-lg"
        >
          <h2 class="text-2xl font-bold text-white mb-6">
            Vista General del Hotel
          </h2>

          <div class="flex flex-col xl:flex-row gap-6">
            <!-- ? 1. Estado de Habitaciones -->
            <div class="flex-1 xl:w-2/3">
              <div
                class="bg-[#0a0a0a] p-6 rounded-xl border border-neutral-800 h-full border-l-4 border-l-blue-600"
              >
                <h3
                  class="text-lg font-semibold text-white flex items-center gap-2 mb-6"
                >
                  <i class="fa-solid fa-bed text-blue-500"></i> Estado de Habitaciones
                </h3>

                <div class="flex justify-around items-center mb-6">
                  <div class="text-center">
                    <p
                      class="text-xs uppercase tracking-widest text-neutral-500 mb-1 font-semibold"
                    >
                      Ocupadas
                    </p>
                    <p class="text-4xl font-bold text-red-500">
                      {habitacionesOcupadas}
                    </p>
                  </div>
                  <div class="text-center">
                    <p
                      class="text-xs uppercase tracking-widest text-neutral-500 mb-1 font-semibold"
                    >
                      Disponibles
                    </p>
                    <p class="text-4xl font-bold text-green-500">
                      {habitacionesLibres}
                    </p>
                  </div>
                </div>

                <div class="overflow-x-auto">
                  <table class="w-full text-left border-collapse min-w-max">
                    <thead>
                      <tr>
                        <th
                          class="border-b border-neutral-800 py-3 px-2 text-neutral-400 font-medium text-sm"
                          >Habitación</th
                        >
                        <th
                          class="border-b border-neutral-800 py-3 px-2 text-neutral-400 font-medium text-sm"
                          >Estado</th
                        >
                        <th
                          class="border-b border-neutral-800 py-3 px-2 text-neutral-400 font-medium text-sm"
                          >Cliente</th
                        >
                        <th
                          class="border-b border-neutral-800 py-3 px-2 text-neutral-400 font-medium text-sm"
                          >Ocupada hasta</th
                        >
                      </tr>
                    </thead>
                    <tbody>
                      {
                        habitacionesStats.map((hab) => (
                          <tr class="hover:bg-neutral-900/50 transition-colors">
                            <td class="py-3 px-2 border-b border-neutral-800/50 text-white font-medium">
                              {hab.nombre}
                            </td>
                            <td class="py-3 px-2 border-b border-neutral-800/50">
                              {hab.ocupada ? (
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-500/10 text-red-400 border border-red-500/20">
                                  Ocupada
                                </span>
                              ) : (
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">
                                  Libre
                                </span>
                              )}
                            </td>
                            <td class="py-3 px-2 border-b border-neutral-800/50">
                              {hab.cliente ? (
                                <span class="text-neutral-300 text-sm">
                                  {hab.cliente}
                                </span>
                              ) : (
                                <span class="text-neutral-600">—</span>
                              )}
                            </td>
                            <td class="py-3 px-2 border-b border-neutral-800/50">
                              {hab.ocupada ? (
                                <span class="text-yellow-500 text-sm">
                                  {hab.fecha_salida}
                                </span>
                              ) : (
                                <span class="text-neutral-600">—</span>
                              )}
                            </td>
                          </tr>
                        ))
                      }
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- ? 2. Ingresos del Mes -->
            <div class="w-full xl:w-1/3">
              <div
                class="bg-[#0a0a0a] p-6 rounded-xl border border-neutral-800 h-full border-l-4 border-l-green-600 flex flex-col justify-between"
              >
                <div>
                  <h3
                    class="text-lg font-semibold text-white flex items-center gap-2 mb-2"
                  >
                    <i class="fa-solid fa-wallet text-green-500"></i> Ingresos del
                    Mes
                  </h3>
                  <p class="text-neutral-500 text-sm mb-6 leading-relaxed">
                    Ingresos estimados para <span
                      class="text-neutral-300 font-medium capitalize"
                      >{nombreMes}</span
                    > basados en {totalReservasMes} reserva(s) del periodo.
                  </p>
                </div>

                <div>
                  <h1 class="text-4xl font-bold text-green-500 mb-6">
                    ${ingresosMes.toLocaleString("es-MX")}
                    <span class="text-xl text-green-600/80">MXN</span>
                  </h1>
                  <div
                    class="w-full h-2.5 bg-neutral-800 rounded-full overflow-hidden mb-2"
                  >
                    <div
                      class="h-full bg-green-500 rounded-full transition-all duration-500"
                      style={`width: ${(habitacionesOcupadas / (habitacionesStats.length || 1)) * 100}%`}
                    >
                    </div>
                  </div>
                  <p class="text-xs text-blue-400 font-medium text-right">
                    Capacidad al {
                      Math.round(
                        (habitacionesOcupadas /
                          (habitacionesStats.length || 1)) *
                          100,
                      )
                    }%
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- ? 3. Roles, Personal y Cuenta -->
          <div class="mt-6">
            <div
              class="bg-[#0a0a0a] p-6 rounded-xl border border-neutral-800 border-l-4 border-l-neutral-600"
            >
              <h3
                class="text-lg font-semibold text-white flex items-center gap-2 mb-6"
              >
                <i class="fa-solid fa-users-gear text-blue-500"></i> Administración
                de Personal y Cuenta
              </h3>

              <div class="flex flex-col md:flex-row gap-6">
                <div class="flex-1">
                  <article
                    class="bg-[#141414] rounded-lg border border-neutral-800 p-5 h-full"
                  >
                    <div class="text-white">
                      <strong class="text-lg block mb-1"
                        >Mi Cuenta (Admin Root)</strong
                      >
                      <span class="text-neutral-500 text-sm"
                        >Rol: Propietario / Superadmin</span
                      >
                      <div class="flex flex-wrap gap-3 mt-4">
                        <button
                          class="border border-blue-500 text-blue-400 hover:bg-blue-600 hover:text-white px-4 py-1.5 text-sm rounded-lg transition-colors font-medium"
                          >Cambiar Contraseña</button
                        >
                        <button
                          class="border border-blue-500 text-blue-400 hover:bg-blue-600 hover:text-white px-4 py-1.5 text-sm rounded-lg transition-colors font-medium"
                          >Ajustes de Seguridad</button
                        >
                      </div>
                    </div>
                  </article>
                </div>
                <div class="flex-1">
                  <article
                    class="bg-[#141414] rounded-lg border border-neutral-800 p-5 h-full"
                  >
                    <div class="text-white">
                      <strong class="text-lg block mb-1"
                        >Gestión de Roles</strong
                      >
                      <span class="text-neutral-500 text-sm"
                        >Personal Activo: 3 (1 Admin, 2 Recepción)</span
                      >
                      <div class="flex flex-wrap gap-3 mt-4">
                        <button
                          class="border border-green-500 text-green-400 hover:bg-green-600 hover:text-white px-4 py-1.5 text-sm rounded-lg transition-colors font-medium"
                          >Añadir Empleado</button
                        >
                        <button
                          class="border border-yellow-500 text-yellow-400 hover:bg-yellow-600 hover:text-white px-4 py-1.5 text-sm rounded-lg transition-colors font-medium"
                          >Modificar Permisos</button
                        >
                      </div>
                    </div>
                  </article>
                </div>
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>
</LayoutAdmin>
