---
// ↓ Importamos nuestra Plantilla Base para admin/
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
// ↓ Importamos el componente de navegación reutilizable del panel
import NavAdmin from "../../components/NavAdmin.astro";
import { supabase } from "../../lib/supabase";

// LA AUTENTICACIÓN AHORA LA MANEJA src/middleware.ts

// Traemos los últimos registros para previsualización del Admin
const { data: ultimasReservas } = await supabase.from('reservas').select('*').order('created_at', { ascending: false }).limit(10);
---

<LayoutAdmin title="Admin | Base de Datos" favicon="/images/database-icon.png">
  <header class="section pb-4 pt-5 has-text-centered">
    <h1 class="title is-3 mb-0">
      <i class="fa-solid fa-gears has-text-info mr-2" aria-hidden="true"></i>
      Panel de Administración
    </h1>
  </header>

  <div class="container is-fluid section pt-0">
    <div class="columns">
      <!-- ! Columna 1: de Navegación -->
      <NavAdmin paginaActual="database" />

      <!-- ! Columna 2: Contenido Principal -->
      <div class="column is-10">
        <main class="box content has-background-black-ter">
          
          <div class="is-flex is-justify-content-space-between is-align-items-center mb-4">
            <h2 class="title is-4 has-text-white m-0">
              <i class="fa-solid fa-server has-text-danger mr-2"></i> Acceso Root BD
            </h2>
            <span class="tag is-danger is-medium">⚠️ ZONA DE ALTO RIESGO</span>
          </div>

          <section id="database">
            <div class="box p-4 has-background-black border-left" style="border-left-color: #f14668;">
              <p class="has-text-grey-light is-family-code is-size-7 mb-4">
                > conectado a supabase_db: port 5432<br/>
                > RLS: habilitado<br/>
                > current_role: authenticated (admin_tier)<br/>
                > Ejecutando consulta: <span class="has-text-success">SELECT * FROM reservas ORDER BY created_at DESC LIMIT 10;</span>
              </p>

              <div class="table-container">
                <table class="table is-fullwidth is-narrow has-background-black has-text-grey-light is-family-code is-size-7">
                  <thead>
                    <tr>
                      <th class="has-text-danger">ID</th>
                      <th class="has-text-info">CLIENTE</th>
                      <th class="has-text-info">HABITACIÓN</th>
                      <th class="has-text-info">CHECK-IN</th>
                      <th class="has-text-info">CHECK-OUT</th>
                      <th class="has-text-danger">ACCIONES (ROOT)</th>
                    </tr>
                  </thead>
                  <tbody>
                    {ultimasReservas && ultimasReservas.length > 0 ? (
                      ultimasReservas.map((res) => (
                        <tr>
                          <td>{res.id}</td>
                          <td class="has-text-white">{res.nombre_cliente}</td>
                          <td>{res.habitacion}</td>
                          <td>{res.fecha_entrada}</td>
                          <td>{res.fecha_salida}</td>
                          <td>
                            <div class="buttons are-small">
                              <button class="button is-black has-text-warning border-warning" onclick={`confirmarAccion('EDITAR', ${res.id})`}>
                                <i class="fa-solid fa-pen"></i>
                              </button>
                              <button class="button is-black has-text-danger border-danger" onclick={`confirmarAccion('ELIMINAR', ${res.id})`}>
                                <i class="fa-solid fa-trash"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                      ))
                    ) : (
                      <tr>
                        <td colspan="6" class="has-text-centered has-text-warning">No hay registros en la tabla 'reservas'</td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>
              
              <!-- TRUNCATE BUTTON REMOVED FOR SECURITY -->
          </section>
        </main>
      </div>
    </div>
  </div>

  <script is:inline>
    async function confirmarAccion(accion, id) {
      const confirmacion = confirm(`[ROOT REQUIRED]\n\n¿Aceptas este cambio [${accion}] en el registro/tabla ID: ${id}?\n\nEsta acción ejecutará comandos en la Base de Datos y es IRREVERSIBLE.`);
      if (confirmacion && accion === 'ELIMINAR') {
        try {
          const res = await fetch(`/api/admin-reservas`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id })
          });
          const data = await res.json();
          if(res.ok) {
            alert(`> Registro ${id} eliminado con éxito.`);
            window.location.reload();
          } else {
            alert(`> Error: ${data.error}`);
          }
        } catch (e) {
          alert(`> Error de conexión al intentar eliminar.`);
        }
      } else if (confirmacion && accion === 'EDITAR') {
        alert("La vista de edición será implementada próximamente.");
      } else {
        console.log(`> Operación '${accion}' abortada por el usuario.`);
      }
    }
  </script>

  <style>
    .border-warning { border: 1px solid #ffe08a !important; }
    .border-danger { border: 1px solid #f14668 !important; }
  </style>
</LayoutAdmin>
