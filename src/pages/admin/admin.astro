---
// ↓ Importamos nuestra Plantilla Base para admin/
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
import { supabase } from "../../lib/supabase";

// Si el usuario ya tiene sesión activa en cookies, redirigir directamente al panel
const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (accessToken && refreshToken) {
  return Astro.redirect("/admin/panel-admin");
}

let errorMsg = "";

// Manejo del formulario vía POST (SSR)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get("username")?.toString(); // Supabase usa Email para Auth
    const password = formData.get("password")?.toString();

    if (email && password) {
      const { data, error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        errorMsg = "Credenciales inválidas. Por favor intente de nuevo.";
      } else {
        Astro.cookies.set("sb-access-token", data.session.access_token, {
          path: "/",
          httpOnly: true,
          secure: true,
          sameSite: "strict", // Prevents CSRF
        });
        Astro.cookies.set("sb-refresh-token", data.session.refresh_token, {
          path: "/",
          httpOnly: true,
          secure: true,
          sameSite: "strict", // Prevents CSRF
        });

        return Astro.redirect("/admin/panel-admin");
      }
    }
  } catch (e) {
    errorMsg = "Error en el servidor al procesar la solicitud.";
  }
}
---

<LayoutAdmin title="Admin Login" favicon="/images/admin-login-icon.png">
  <header class="container mx-auto px-4 text-center mt-12 mb-8">
    <h1 class="text-4xl font-bold text-white">Bienvenido Sr. Admin</h1>
  </header>

  <main class="grow">
    <section id="login-admin" class="py-8 px-4 container mx-auto">
      <h2
        class="text-2xl text-neutral-300 flex items-center justify-center gap-3 mb-10"
      >
        <span class="flex items-center text-blue-500">
          <i class="fa-solid fa-lock" aria-hidden="true"></i>
        </span>
        Inicio de sesión
      </h2>

      <div class="w-full md:w-1/3 mx-auto">
        <form method="post" action="/admin/admin">
          <fieldset
            id="admin-credenciales"
            class="bg-[#141414] p-8 rounded-2xl border border-neutral-800 shadow-xl"
          >
            <legend
              class="text-lg font-semibold text-white px-3 bg-[#0a0a0a] rounded-lg border border-neutral-800 ml-4 py-1"
              >Credenciales de Acceso</legend
            >

            {
              errorMsg && (
                <div class="bg-red-900/40 border border-red-500 text-red-200 p-3 mb-6 rounded-lg text-center text-sm font-medium">
                  <p>{errorMsg}</p>
                </div>
              )
            }

            <!-- ? Campos de Llenado -->
            <div class="mb-5">
              <label
                class="block text-sm font-medium text-neutral-400 mb-2"
                for="username">Correo Electrónico:</label
              >
              <div class="relative">
                <input
                  class="w-full bg-[#0a0a0a] border border-neutral-700 rounded-lg pl-10 pr-4 py-2.5 text-white placeholder-neutral-600 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all"
                  type="email"
                  id="username"
                  name="username"
                  placeholder="admin@hotel.com"
                  required
                />
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-500"
                >
                  <i class="fa-solid fa-envelope"></i>
                </span>
              </div>
            </div>

            <div class="mb-6">
              <label
                class="block text-sm font-medium text-neutral-400 mb-2"
                for="password">Contraseña:</label
              >
              <div class="relative">
                <input
                  class="w-full bg-[#0a0a0a] border border-neutral-700 rounded-lg pl-10 pr-4 py-2.5 text-white placeholder-neutral-600 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all"
                  type="password"
                  id="password"
                  name="password"
                  placeholder="********"
                  required
                />
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-500"
                >
                  <i class="fa-solid fa-key"></i>
                </span>
              </div>
            </div>
            <!-- ? Botones -->
            <div class="flex justify-center gap-4 mt-8">
              <button
                type="submit"
                class="flex-1 bg-green-600 hover:bg-green-700 text-white font-medium py-2.5 px-4 rounded-lg transition-colors border-none cursor-pointer"
              >
                Iniciar Sesión
              </button>
              <button
                type="reset"
                class="flex-1 bg-transparent border border-red-500 text-red-500 hover:bg-red-500 hover:text-white font-medium py-2.5 px-4 rounded-lg transition-colors cursor-pointer"
              >
                Limpiar
              </button>
            </div>
          </fieldset>
        </form>
      </div>
    </section>
  </main>

  <!-- Botón flotante animado para regresar a la página principal -->
  <a
    href="/"
    class="fixed bottom-8 right-8 bg-[#141414] border border-neutral-800 text-neutral-400 hover:text-white hover:border-neutral-600 px-4 py-3 rounded-full shadow-2xl transition-all duration-300 flex items-center gap-0 hover:gap-3 group z-50 overflow-hidden"
  >
    <i
      class="fa-solid fa-house group-hover:text-blue-500 transition-colors pl-1"
    ></i>
    <span
      class="max-w-0 opacity-0 group-hover:max-w-[140px] group-hover:opacity-100 whitespace-nowrap transition-all duration-500 ease-in-out text-sm font-medium pr-1"
      >Volver al sitio web</span
    >
  </a>
</LayoutAdmin>
