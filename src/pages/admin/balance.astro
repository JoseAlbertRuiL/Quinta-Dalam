---
// ↓ Importamos nuestra Plantilla Base para admin/
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
// ↓ Importamos el componente de navegación reutilizable del panel
import NavAdmin from "../../components/NavAdmin.astro";
import { supabase } from "../../lib/supabase.js";

// VERIFICACIÓN DE SESIÓN (Protección de Ruta SSR)
const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
  return Astro.redirect("/admin/admin");
}

const { error } = await supabase.auth.setSession({
  access_token: accessToken.value,
  refresh_token: refreshToken.value,
});

if (error) {
  Astro.cookies.delete("sb-access-token", { path: "/" });
  Astro.cookies.delete("sb-refresh-token", { path: "/" });
  return Astro.redirect("/admin/admin");
}
---

<LayoutAdmin title="Admin | Balance" favicon="/images/balance-icono.png">
  <header class="section pb-4 pt-5 has-text-centered">
    <h1 class="title is-3 mb-0">
      <i class="fa-solid fa-gears has-text-info mr-2" aria-hidden="true"></i>
      Panel de Administración
    </h1>
  </header>

  <div class="container section pt-0">
    <div class="columns">
      <!-- ! Columna 1: de Navegación -->
      <NavAdmin paginaActual="balance" />

      <!-- ! Columna 2: Contenido Principal -->
      <div class="column is-10">
        <main class="box content">
          <section id="balance">
            <details open class="box p-4 has-background-black-ter">
              <summary class="is-clickable m-0 p-0" style="list-style: none">
                <h3 class="title is-5 is-inline-block m-0">
                  <i class="fa-solid fa-cash-register has-text-info mr-2"></i>
                  Balance y Caja
                </h3>
              </summary>
              <div class="mt-4 pl-4 border-left has-text-white">
                <div class="box">
                  <h5 class="title is-5 mb-4 has-text-white">
                    Resumen de Estados
                  </h5>
                  <ul
                    class="is-size-6 has-text-grey-light"
                    style="list-style-type: none; margin-left: 0"
                  >
                    <li class="mb-4">
                      <strong class="has-text-info">Saldo Total en Caja:</strong
                      >
                      Actualmente en [x] fecha se dispone de $[y]MXN en efectivo.
                    </li>
                    <li class="mb-4">
                      <strong class="has-text-info">Balance Bancario:</strong>
                      Actualmente dentro de nuestro balance bancario (integrando cuentas
                      digitales y de bancos) contamos con un saldo de: $[y]MXN
                    </li>
                    <li class="mb-4">
                      <strong class="has-text-info">Ingresos del Mes:</strong>
                      Actualmente percibimos un ingreso mensual estimado de $[x]MXN,
                      de los cuales se estuvieron de estos diferentes ingresos:
                      <ol type="a" class="mt-2 ml-5 has-text-grey-light">
                        <li class="mb-2">
                          Restaurante: $[x]MXN, de los cuales representan un
                          [y]% de nuestros ingresos <em>totales</em>.
                        </li>
                        <li class="mb-2">
                          Hotel (Habitaciones): $[x]MXN, de los cuales
                          representan un [y]% de nuestros ingresos
                          <em>totales</em>.
                        </li>
                        <li class="mb-2">
                          Snacks, room service & máquina expendedora: $[x]MXN,
                          de los cuales representan un [y]% de nuestros ingresos <em
                            >totales</em
                          >.
                        </li>
                      </ol>
                    </li>
                  </ul>
                </div>
              </div>
            </details>
          </section>
        </main>
      </div>
    </div>
  </div>
</LayoutAdmin>
