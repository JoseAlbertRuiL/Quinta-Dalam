---
// ↓ Importamos nuestra Plantilla Base para admin/
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
// ↓ Importamos el componente de navegación reutilizable del panel
import NavAdmin from "../../components/NavAdmin.astro";
import { supabase } from "../../lib/supabase";

// LA AUTENTICACIÓN AHORA LA MANEJA src/middleware.ts
---

<LayoutAdmin title="Admin | Balance" favicon="/images/balance-icono.png">
  <header class="py-10 px-4 text-center">
    <h1 class="text-3xl font-bold text-white flex items-center justify-center gap-3">
      <i class="fa-solid fa-gears text-blue-500" aria-hidden="true"></i>
      Panel de Administración
    </h1>
  </header>

  <div class="w-full px-4 md:px-8 pb-10">
    <div class="flex flex-col md:flex-row gap-6">
      <!-- ! Columna 1: de Navegación -->
      <NavAdmin paginaActual="balance" />

      <!-- ! Columna 2: Contenido Principal -->
      <div class="flex-1">
        <main class="bg-[#141414] p-6 lg:p-8 rounded-xl border border-neutral-800/50 shadow-lg">
          <section id="balance">
            <details open class="bg-[#0a0a0a] rounded-xl border border-neutral-800 p-6">
              <summary class="cursor-pointer list-none m-0 p-0 focus:outline-none">
                <h3 class="text-xl font-bold text-white inline-flex items-center gap-3 m-0">
                  <i class="fa-solid fa-cash-register text-blue-500"></i>
                  Balance y Caja
                </h3>
              </summary>
              <div class="mt-6 pl-5 border-l-4 border-l-blue-600 text-neutral-300">
                <div class="bg-[#141414] rounded-lg border border-neutral-800 p-5">
                  <h5 class="text-lg font-bold mb-5 text-white">
                    Resumen de Estados
                  </h5>
                  <ul class="text-base text-neutral-400 space-y-4">
                    <li>
                      <strong class="text-blue-400 font-semibold">Saldo Total en Caja: </strong>
                      Actualmente en [x] fecha se dispone de $[y]MXN en efectivo.
                    </li>
                    <li>
                      <strong class="text-blue-400 font-semibold">Balance Bancario: </strong>
                      Actualmente dentro de nuestro balance bancario (integrando cuentas
                      digitales y de bancos) contamos con un saldo de: $[y]MXN
                    </li>
                    <li>
                      <strong class="text-blue-400 font-semibold">Ingresos del Mes: </strong>
                      Actualmente percibimos un ingreso mensual estimado de $[x]MXN,
                      de los cuales se obtuvieron de estos diferentes ingresos:
                      <ol type="a" class="mt-3 ml-6 text-neutral-500 space-y-2 list-[lower-alpha]">
                        <li>
                          Restaurante: $[x]MXN, de los cuales representan un
                          [y]% de nuestros ingresos <em class="text-neutral-300 not-italic font-medium">totales</em>.
                        </li>
                        <li>
                          Hotel (Habitaciones): $[x]MXN, de los cuales
                          representan un [y]% de nuestros ingresos
                          <em class="text-neutral-300 not-italic font-medium">totales</em>.
                        </li>
                        <li>
                          Snacks, room service & máquina expendedora: $[x]MXN,
                          de los cuales representan un [y]% de nuestros ingresos 
                          <em class="text-neutral-300 not-italic font-medium">totales</em>.
                        </li>
                      </ol>
                    </li>
                  </ul>
                </div>
              </div>
            </details>
          </section>
        </main>
      </div>
    </div>
  </div>
</LayoutAdmin>
