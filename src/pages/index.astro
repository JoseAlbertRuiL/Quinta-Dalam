---
// Importamos nuestra Plantilla Base
import Layout from "../layouts/Layout.astro";

// También podemos definir variables
const tituloPagina = "Hotel Quinta Dalam";
---

<!--
Usamos nuestra importaciones usando nuestro Layout (que ya contiene la Base, Header & Footer).
Al usar title="", le pasamos la variable al <head> de la página en cuestión 
-->
<Layout title={tituloPagina}>
  <main>
    <!-- * <main>: Define el contenido principal y único de la página web dentro del <body> -->
    <!-- Sección Inicio / Hero -->
    <section id="inicio">
      <!-- ? <section>: Sirve para dividir semánticamente en partes diferentes los elementos HTML -->
      <header>
        <!--? <header>: Indica el título o titural de la sección -->
        <h2>Vive la magia de Michoacán en cada rincón.</h2>
        <!-- Eslogan o frase insignia -->
      </header>
      <div>
        <p>
          Bienvenido a <strong>Hotel Quinta Dalam</strong>, un espacio diseñado
          para que vivas la experiencia de los Pueblos Mágicos de Michoacán.
        </p>
        <p>
          En <strong>Hotel Quinta Dalam</strong>
          contamos con 15 habitaciones temáticas y todos los servicios para una estadía
          inolvidable.
        </p>
      </div>
    </section>

    <!-- Sección Acerca de -->
    <section id="acerca-de">
      <header>
        <h2>Acerca de Nosotros</h2>
      </header>
      <p>
        Nació de la inspiración por la riqueza cultural de nuestro estado.
        <strong>Hotel Quinta Dalam</strong>
        busca resaltar la belleza de los Pueblos Mágicos de Michoacán en cada detalle.
      </p>
      <p>
        Ofrecemos un ambiente acogedor y lleno de tradición, donde cada una de
        nuestras 15 habitaciones cuenta una historia diferente. ¡Ven a
        descubrirlo!
        <br />
        ¡Atrévete a descubrir esta experiencia inolvidable!
      </p>
    </section>

    <!-- TODO (Alberto): Mejorar el vídeo con CSS -->
    <section id="video">
      <header>
        <h3 style="display: none">Bienvenido</h3>
      </header>
      <div>
        <video
          class="hero-video"
          autoplay
          muted
          loop
          src="media/showcase_hotel.mp4"></video>
      </div>
    </section>

    <section id="features">
      <!-- * Contenedor Grid para las 3 secciones -->
      <div class="seccion-grid">
        <!-- Instalaciones -->
        <div class="seccion-item">
          <h2>Instalaciones</h2>
          <a href="pages/instalaciones.html">
            <img
              title="Instalaciones del hotel"
              loading="lazy"
              src="images/Instalaciones.png"
              alt="Ver más detalles de nuestras instalaciones"
            />
          </a>
          <p>
            Explora nuestros espacios inspirados en la arquitectura colonial,
            patios y jardines que te transportarán a lo mejor de Michoacán.
          </p>
        </div>

        <!-- Habitaciones -->
        <div class="seccion-item">
          <h2>Habitaciones</h2>
          <a href="pages/habitaciones.html">
            <img
              title="Habitaciones del hotel"
              loading="lazy"
              src="images/habitacion.png"
              alt="Ver más detalles de nuestras habitaciones"
            />
          </a>
          <p>
            Vive una experiencia única en nuestras 15 habitaciones temáticas,
            cada una rindiendo homenaje a un Pueblo Mágico distinto.
          </p>
        </div>

        <!-- Servicios -->
        <div class="seccion-item">
          <h2>Servicios</h2>
          <a href="pages/servicios.html">
            <img
              title="Servicios premium"
              loading="lazy"
              src="images/servicios2.jpg"
              alt="Ver más detalles de nuestro servicio de restaurant"
            />
          </a>
          <p>
            Disfruta de servicios diseñados para consentirte, desde gastronomía
            típica hasta una atención personalizada para tu estadía mágica
            viviendo Michoacán en cada momento.
          </p>
        </div>
      </div>
    </section>

    <!-- Sección Reservar -->
    <section id="reservar">
      <header>
        <h2>Reservar</h2>
      </header>
      <h3>¿Estás listo para reservar?</h3>
      <div>
        <p>
          Ingresa a nuestra página de
          <a href="pages/reservaciones.html">reservaciones</a>
          para poder apartar tu lugar en un paraíso en Morelia Michoacán. También
          puedes reservar rápidamente en nuestro
          <a
            href="https://wa.me/443212345678?text=Hola,%20me%20gustar%C3%ADa%20reservar%20una%20habitación%20en%20Hotel%20Quinta%20Dalam"
            style="display: inline-flex; align-items: center; gap: 5px"
            target="_blank"
            aria-label="Reservar por WhatsApp"
          >
            <i class="fa-brands fa-whatsapp"></i>
            WhatsApp
          </a>
        </p>
      </div>
    </section>
  </main>
</Layout>
