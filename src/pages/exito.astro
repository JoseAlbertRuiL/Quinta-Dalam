---
// ↓ Importamos nuestra Plantilla Base
import Layout from "../layouts/Layout.astro";
---

<Layout title="¡Reservación Confirmada! | Hotel Quinta Dalam">


  <main class="exito-page">
    <!-- ======================== CONTENIDO DE ÉXITO ======================== -->
    <section class="exito-container" id="exito-container">
      <!-- ↓ Ícono animado de éxito -->
      <div class="exito-icon">
        <svg
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="white"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>

      <h1 class="exito-title">¡Reservación Confirmada!</h1>
      <p class="exito-subtitle">
        Tu pago ha sido procesado exitosamente. Recibirás un correo de
        confirmación en breve.
      </p>

      <div class="exito-sep"></div>

      <!-- ↓ Tarjeta de resumen con todos los datos de la reservación -->
      <div class="exito-summary-card">
        <div class="exito-summary-header">
          <div class="exito-summary-icon">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="white"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </div>
          <span class="exito-summary-title">Resumen de tu Reservación</span>
        </div>

        <!-- ? Los valores se inyectan dinámicamente con JS desde sessionStorage -->
        <div class="exito-row">
          <span class="exito-label">Huésped</span>
          <span class="exito-value" id="exito-name">—</span>
        </div>
        <div class="exito-divider"></div>
        <div class="exito-row">
          <span class="exito-label">Correo</span>
          <span class="exito-value" id="exito-email">—</span>
        </div>
        <div class="exito-divider"></div>
        <div class="exito-row">
          <span class="exito-label">Teléfono</span>
          <span class="exito-value" id="exito-tel">—</span>
        </div>
        <div class="exito-divider"></div>
        <div class="exito-row">
          <span class="exito-label">Llegada</span>
          <span class="exito-value" id="exito-llegada">—</span>
        </div>
        <div class="exito-divider"></div>
        <div class="exito-row">
          <span class="exito-label">Salida</span>
          <span class="exito-value" id="exito-salida">—</span>
        </div>
        <div class="exito-divider"></div>
        <div class="exito-row">
          <span class="exito-label">Personas</span>
          <span class="exito-value" id="exito-personas">—</span>
        </div>
        <div class="exito-divider"></div>
        <div class="exito-row">
          <span class="exito-label">Habitación</span>
          <span class="exito-value" id="exito-room">—</span>
        </div>

        <div class="exito-nights-badge" id="exito-nights-container">
          <span class="exito-nights-label">Estancia total</span>
          <span class="exito-nights-value" id="exito-nights">—</span>
        </div>
      </div>

      <!-- ↓ Botón para volver al inicio -->
      <a href="/" class="exito-home-btn">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
        Volver al Inicio
      </a>

    </section>

    <!-- ↓ Contenido de error si no hay datos -->
    <section class="exito-no-data" id="exito-no-data" style="display: none;">
      <div class="exito-icon" style="background: linear-gradient(135deg, #c9a96e, #dbc28e);">
        <svg
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="white"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
      </div>
      <h2 class="exito-title" style="font-size: 1.8rem;">No hay reservación activa</h2>
      <p class="exito-subtitle">
        No encontramos datos de una reservación reciente. Por favor, realiza una
        nueva reservación.
      </p>
      <a href="/reservaciones" class="exito-home-btn">
        Ir a Reservaciones
      </a>
    </section>
  </main>

  <style>
    /* ==================== PÁGINA DE ÉXITO - ESTILOS ==================== */

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes scaleIn {
      from {
        transform: scale(0.7);
        opacity: 0;
      }
      to {
        transform: scale(1);
        opacity: 1;
      }
    }

    .exito-page {
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem 1.5rem;
      font-family: "Jost", sans-serif;
      background: radial-gradient(
          ellipse at 20% 20%,
          rgba(79, 121, 66, 0.06) 0%,
          transparent 60%
        ),
        radial-gradient(
          ellipse at 80% 80%,
          rgba(201, 169, 110, 0.07) 0%,
          transparent 60%
        );
    }

    .exito-container,
    .exito-no-data {
      max-width: 560px;
      width: 100%;
      text-align: center;
      animation: fadeUp 0.7s ease both;
    }

    .exito-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: linear-gradient(135deg, #1a4d2e, #4f7942);
      margin: 0 auto 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: scaleIn 0.5s 0.3s ease both;
      box-shadow: 0 12px 32px rgba(26, 77, 46, 0.35);
    }

    .exito-title {
      font-family: "Cormorant Garamond", serif;
      font-size: 2.6rem;
      font-weight: 600;
      color: #1a2e1a;
      margin: 0 0 0.75rem;
      line-height: 1.1;
    }

    .exito-subtitle {
      color: #5a6b5a;
      font-size: 1.05rem;
      font-weight: 500;
      line-height: 1.7;
      margin: 0 0 1.5rem;
    }

    .exito-sep {
      width: 80px;
      height: 2px;
      background: linear-gradient(to right, transparent, #c9a96e, transparent);
      margin: 0 auto 2rem;
    }

    /* Tarjeta de resumen */
    .exito-summary-card {
      background: white;
      border-radius: 16px;
      padding: 1.8rem;
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
      border: 1px solid rgba(0, 0, 0, 0.06);
      text-align: left;
      margin-bottom: 2rem;
      animation: fadeUp 0.6s 0.4s ease both;
    }

    .exito-summary-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.4rem;
      padding-bottom: 1.1rem;
      border-bottom: 1px solid #ebe8e0;
    }

    .exito-summary-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: linear-gradient(135deg, #1a4d2e, #4f7942);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .exito-summary-title {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.3rem;
      font-weight: 600;
      color: #1a2e1a;
    }

    .exito-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.45rem 0;
      font-size: 0.875rem;
    }

    .exito-label {
      color: #8a9a8a;
      font-weight: 400;
      letter-spacing: 0.02em;
    }

    .exito-value {
      color: #2a3a2a;
      font-weight: 500;
      text-align: right;
      max-width: 55%;
    }

    .exito-divider {
      height: 1px;
      background: #f0ece4;
      margin: 0.8rem 0;
    }

    .exito-nights-badge {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.7rem 1rem;
      background: linear-gradient(135deg, #f0f7f0, #e8f3e8);
      border-radius: 10px;
      margin-top: 0.8rem;
    }

    .exito-nights-label {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.05rem;
      color: #1a4d2e;
      font-style: italic;
    }

    .exito-nights-value {
      background: linear-gradient(135deg, #1a4d2e, #4f7942);
      color: white;
      padding: 0.3rem 0.8rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.04em;
    }

    /* Botón de inicio — hover con realce de brillo suave, sin cambio brusco de color */
    .exito-home-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.85rem 2rem;
      font-family: var(--font-body);
      font-size: 1.1rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: white;
      background: linear-gradient(135deg, #1a4d2e 0%, #4f7942 100%);
      border: none;
      border-radius: 12px;
      cursor: pointer;
      text-decoration: none;
      box-shadow: 0 6px 20px rgba(26, 77, 46, 0.35);
      transition: transform 0.35s ease, box-shadow 0.35s ease, filter 0.35s ease;
      margin-bottom: 1.5rem;
    }

    .exito-home-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(26, 77, 46, 0.4);
      filter: brightness(1.12);
      color: white;
    }

    .exito-home-btn:active {
      transform: translateY(0);
    }


    /* Responsive */
    @media (max-width: 600px) {
      .exito-title {
        font-size: 2rem;
      }

      .exito-summary-card {
        padding: 1.3rem;
      }

      .exito-page {
        padding: 2rem 1rem;
      }
    }
  </style>

  <script>
    function initExito() {
      const container = document.getElementById("exito-container");
      const noData = document.getElementById("exito-no-data");

      // ↓ Leer los datos de la reservación guardados por PagosForm
      const raw = sessionStorage.getItem("reservacionData");

      if (!raw) {
        // No hay datos: mostrar mensaje de error
        if (container) container.style.display = "none";
        if (noData) noData.style.display = "block";
        return;
      }

      const data = JSON.parse(raw);

      // ↓ Inyectar los datos en el DOM
      const setText = (id: string, text: string) => {
        const el = document.getElementById(id);
        if (el) el.textContent = text;
      };

      const formatDate = (dateStr: string) => {
        const date = new Date(dateStr + "T00:00:00");
        return date.toLocaleDateString("es-MX", {
          day: "numeric",
          month: "long",
          year: "numeric",
        });
      };

      setText("exito-name", data.name || "—");
      setText("exito-email", data.email || "—");
      setText(
        "exito-tel",
        `${data.countryCode || ""} ${data.tel || ""}`.trim() || "—",
      );
      setText("exito-llegada", data.fechaLlegada ? formatDate(data.fechaLlegada) : "—");
      setText("exito-salida", data.fechaSalida ? formatDate(data.fechaSalida) : "—");
      setText("exito-personas", data.numeroPersonas || "—");
      setText("exito-room", data.roomPreference || "—");

      // ↓ Calcular y mostrar noches
      if (data.fechaLlegada && data.fechaSalida) {
        const llegada = new Date(data.fechaLlegada);
        const salida = new Date(data.fechaSalida);
        const nights = Math.max(
          1,
          Math.round(
            (salida.getTime() - llegada.getTime()) / 86400000,
          ),
        );
        setText(
          "exito-nights",
          `${nights} ${nights === 1 ? "noche" : "noches"}`,
        );
      }

      // ↓ Limpiar todos los datos de sessionStorage tras mostrar la confirmación
      sessionStorage.removeItem("reservacionData");
      sessionStorage.removeItem("res_checkin");
      sessionStorage.removeItem("res_checkout");
      sessionStorage.removeItem("res_personas");
      sessionStorage.removeItem("res_name");
      sessionStorage.removeItem("res_email");
      sessionStorage.removeItem("res_country_code");
      sessionStorage.removeItem("res_tel");
      sessionStorage.removeItem("res_room");
      sessionStorage.removeItem("res_terms");
    }

    document.addEventListener("DOMContentLoaded", initExito);
    document.addEventListener("astro:page-load", initExito);
  </script>
</Layout>
