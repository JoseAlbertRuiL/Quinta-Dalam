---
// ↓ Definimos una constante para manejar las diferentes páginas del panel
// ↓ La página padre nos pasa su identificador mediante esta prop
const { paginaActual } = Astro.props;

const linkClass = "flex items-center px-4 py-2 rounded-lg transition-colors duration-200";
const activeClass = "bg-blue-600 text-white font-medium shadow-md shadow-blue-500/20";
const inactiveClass = "text-neutral-400 hover:bg-[#242424] hover:text-white";
---

<div class="w-full md:w-1/6 shrink-0">
  <nav
    id="indice"
    class="bg-[#141414] p-5 rounded-xl border border-neutral-800/50 shadow-lg"
    aria-label="Menú del panel de administración"
  >
    <p class="uppercase tracking-widest text-xs font-semibold text-neutral-500 mb-4 px-2">Menú Principal</p>
    <ul class="flex flex-col gap-1">
      <li>
        <a
          href="/admin/panel-admin"
          class={`${linkClass} ${paginaActual === "panel-admin" ? activeClass : inactiveClass}`}
        >
          <span class="w-6 flex justify-center mr-3">
            <i class="fa-solid fa-house" aria-hidden="true"></i>
          </span>
          Vista General
        </a>
      </li>
      <li>
        <a
          href="/admin/inbox"
          class={`${linkClass} ${paginaActual === "inbox" ? activeClass : inactiveClass}`}
        >
          <span class="w-6 flex justify-center mr-3">
            <i class="fa-solid fa-inbox" aria-hidden="true"></i>
          </span>
          Inbox
        </a>
      </li>
      <li>
        <a
          href="/admin/stats"
          class={`${linkClass} ${paginaActual === "stats" ? activeClass : inactiveClass}`}
        >
          <span class="w-6 flex justify-center mr-3">
            <i class="fa-solid fa-chart-column" aria-hidden="true"></i>
          </span>
          Estadísticas
        </a>
      </li>
      <li>
        <a
          href="/admin/balance"
          class={`${linkClass} ${paginaActual === "balance" ? activeClass : inactiveClass}`}
        >
          <span class="w-6 flex justify-center mr-3">
            <i class="fa-solid fa-cash-register" aria-hidden="true"></i>
          </span>
          Balance y Caja
        </a>
      </li>
      <li>
        <a
          href="/admin/database"
          class={`${linkClass} ${paginaActual === "database" ? activeClass : inactiveClass}`}
        >
          <span class="w-6 flex justify-center mr-3">
            <i class="fa-solid fa-database" aria-hidden="true"></i>
          </span>
          Base de Datos
        </a>
      </li>
      <li>
        <a
          href="/admin/dev"
          class={`${linkClass} ${paginaActual === "dev" ? activeClass : inactiveClass}`}
        >
          <span class="w-6 flex justify-center mr-3">
            <i class="fa-solid fa-laptop-code" aria-hidden="true"></i>
          </span>
          Desarrollo
        </a>
      </li>
    </ul>
    <form action="/api/logout" method="post" class="mt-6 border-t border-neutral-800 pt-4">
      <button
        type="submit"
        class="w-full flex items-center justify-center gap-2 rounded-full border border-red-500/50 text-red-400 px-4 py-2 hover:bg-red-500 hover:text-white transition-all duration-200"
      >
        <span class="flex items-center">
          <i class="fa-solid fa-sign-out" aria-hidden="true"></i>
        </span>
        <span class="font-medium">Cerrar Sesión</span>
      </button>
    </form>
  </nav>
</div>
